{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@mantajs/core": ["../../mantajs/packages/core/src/index.ts"],
      "@mantajs/test-utils": ["../../mantajs/packages/test-utils/src/index.ts"],
      "@mantajs/test-utils/pg": ["../../mantajs/packages/test-utils/src/pg.ts"],
      "@mantajs/adapter-cache-upstash": ["../../mantajs/packages/adapter-cache-upstash/src/index.ts"],
      "@mantajs/adapter-database-pg": ["../../mantajs/packages/adapter-database-pg/src/index.ts"],
      "@mantajs/adapter-h3": ["../../mantajs/packages/adapter-h3/src/index.ts"],
      "@mantajs/adapter-jobs-vercel-cron": ["../../mantajs/packages/adapter-jobs-vercel-cron/src/index.ts"],
      "@mantajs/adapter-logger-pino": ["../../mantajs/packages/adapter-logger-pino/src/index.ts"],
      "@mantajs/adapter-notification-resend": ["../../mantajs/packages/adapter-notification-resend/src/index.ts"],
      "@mantajs/adapter-queue-qstash": ["../../mantajs/packages/adapter-queue-qstash/src/index.ts"],
      "@mantajs/cli": ["../../mantajs/packages/cli/src/index.ts"],
      "@mantajs/dashboard": ["../../mantajs/packages/dashboard/src/index.tsx"],
      "@mantajs/dashboard-core": ["../../mantajs/packages/dashboard-core/src/index.ts"],
      "@mantajs/host-nitro": ["../../mantajs/packages/host-nitro/src/index.ts"],
      "@mantajs/plugin-posthog-proxy": ["../../mantajs/packages/plugin-posthog-proxy/src/index.ts"],
      "@mantajs/sdk": ["../../mantajs/packages/sdk/src/index.ts"],
      "@mantajs/ui": ["../../mantajs/packages/ui/src/index.ts"]
    }
  },
  "include": [
    "../../mantajs/packages/core/src/globals.d.ts",
    "tests/**/*.ts",
    "demo/commerce/manta.config.ts",
    "demo/commerce/src/**/*.ts",
    "demo/commerce/src/**/*.tsx",
    "demo/commerce/tests/**/*.ts",
    "demo/commerce/.manta/generated.d.ts"
  ],
  "exclude": ["**/dist/**", "demo/**/.manta/server/**", "demo/**/.manta/spa/**", "tests/runtime/**"]
}
