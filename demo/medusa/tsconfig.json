{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "outDir": ".medusa/server",
    "rootDir": "src",
    "declaration": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "medusa-config.ts"]
}
