{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx vite build && npx nitropack build",
  "installCommand": "cd ../.. && pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/admin/:path*", "destination": "/admin/index.html" }
  ],
  "crons": [
    {
      "path": "/api/crons/cleanup-drafts",
      "schedule": "0 */6 * * *"
    }
  ]
}
