{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "rewrites": [
    {
      "source": "/",
      "destination": "/admin"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/crons/detect-abandoned-carts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/crons/sync-from-shopify",
      "schedule": "45 * * * *"
    },
    {
      "path": "/api/crons/sync-klaviyo-events",
      "schedule": "20 * * * *"
    },
    {
      "path": "/api/crons/sync-posthog-events",
      "schedule": "*/5 * * * *"
    }
  ]
}
