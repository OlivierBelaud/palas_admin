{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "rewrites": [
    {
      "source": "/",
      "destination": "/admin"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/crons/detect-abandoned-carts",
      "schedule": "0 */6 * * *"
    }
  ]
}
