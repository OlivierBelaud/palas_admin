{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "regions": ["fra1"],
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && cd demo/commerce && ./node_modules/.bin/manta generate && node scripts/prepare-root-spa-public.mjs && ./node_modules/.bin/manta build --preset vercel --no-migrate && node scripts/patch-root-spa-vercel.mjs",
  "redirects": [
    {
      "source": "/admin/login",
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/admin/reset-password",
      "destination": "/reset-password",
      "permanent": false
    },
    {
      "source": "/admin/accept-invite",
      "destination": "/accept-invite",
      "permanent": false
    },
    {
      "source": "/admin",
      "destination": "/dashboard",
      "permanent": false
    },
    {
      "source": "/admin/:path*",
      "destination": "/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
