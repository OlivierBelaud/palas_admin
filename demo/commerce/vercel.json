{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "regions": ["fra1"],
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && cd demo/commerce && ./node_modules/.bin/manta generate && node scripts/prepare-root-spa-public.mjs && ./node_modules/.bin/manta build --preset vercel --no-migrate && node scripts/patch-root-spa-vercel.mjs",
  "redirects": [
    {
      "source": "/admin/login",
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/admin/reset-password",
      "destination": "/reset-password",
      "permanent": false
    },
    {
      "source": "/admin/accept-invite",
      "destination": "/accept-invite",
      "permanent": false
    },
    {
      "source": "/admin",
      "destination": "/dashboard",
      "permanent": false
    },
    {
      "source": "/admin/:path*",
      "destination": "/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/crons/detect-abandoned-carts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/crons/flush-ga4-dispatches",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/crons/flush-google-ads-dispatches",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/crons/purge-event-hub-logs",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/crons/reconcile-shopify-daily",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/crons/reconcile-shopify-orders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/crons/refresh-visitor-lifecycle-facts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/crons/run-system-audits-nightly",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/crons/send-daily-reporting-email",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/crons/sync-from-shopify",
      "schedule": "45 * * * *"
    },
    {
      "path": "/api/crons/sync-klaviyo-events",
      "schedule": "20 * * * *"
    },
    {
      "path": "/api/crons/sync-posthog-events",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/crons/sync-visitor-sessions",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/crons/test-abandoned-cart-random",
      "schedule": "* * * * *"
    }
  ]
}
