{
  "runtime": "nodejs24.x",
  "regions": ["fra1"],
  "functions": [
    { "source": "admin-me.mjs", "route": "api/admin/me" },
    { "source": "admin-graph.mjs", "route": "api/admin/graph" },
    { "source": "admin-cart-stats.mjs", "route": "api/admin/cart-stats" },
    { "source": "admin-charts-lab-data.mjs", "route": "api/admin/charts-lab-data" },
    { "source": "admin-users.mjs", "route": "api/admin/users" },
    { "source": "admin-invitations.mjs", "route": "api/admin/invitations" },
    {
      "source": "admin-catalog-taxonomy.mjs",
      "route": "api/admin/catalog-taxonomy",
      "extraSources": [
        "catalog-classification-seed.json",
        "catalog-shopify-sync.mjs",
        "catalog-publication-governance.mjs"
      ],
      "maxDuration": 300
    },
    {
      "source": "admin-catalog-content.mjs",
      "route": "api/admin/catalog-content",
      "extraSources": ["catalog-publication-governance.mjs"]
    },
    { "source": "admin-visitor-lifecycle-dashboard.mjs", "route": "api/admin/visitor-lifecycle-dashboard" },
    { "source": "admin-visitor-stats.mjs", "route": "api/admin/visitor-stats-unique-visitors-by-segment" },
    { "source": "admin-visitor-stats.mjs", "route": "api/admin/visitor-stats-carts-created-funnel" },
    { "source": "admin-visitor-stats.mjs", "route": "api/admin/visitor-stats-carts-updated-funnel" },
    { "source": "admin-visitor-stats.mjs", "route": "api/admin/visitor-stats-identity-acquisitions" },
    { "source": "admin-visitor-stats.mjs", "route": "api/admin/visitor-stats-paid-vs-organic" },
    {
      "source": "admin-abandoned-cart-campaign-dashboard.mjs",
      "route": "api/admin/abandoned-cart-campaign-dashboard",
      "extraSources": ["abandoned-cart-campaign-common.mjs"]
    },
    {
      "source": "admin-abandoned-cart-campaign-case-list.mjs",
      "route": "api/admin/abandoned-cart-campaign-case-list",
      "extraSources": ["abandoned-cart-campaign-common.mjs"]
    },
    {
      "source": "admin-abandoned-cart-campaign-message-list.mjs",
      "route": "api/admin/abandoned-cart-campaign-message-list",
      "extraSources": ["abandoned-cart-campaign-common.mjs"]
    },
    {
      "source": "admin-abandoned-cart-campaign-check-list.mjs",
      "route": "api/admin/abandoned-cart-campaign-check-list",
      "extraSources": ["abandoned-cart-campaign-common.mjs"]
    },
    { "source": "admin-system-dashboard.mjs", "route": "api/cart-tracking/admin-system-dashboard" },
    { "source": "admin-tracking-health.mjs", "route": "api/cart-tracking/admin-tracking-health" }
  ]
}
