# Commerce demo env template. Copy to `.env.local` and fill in real values.
# Both `.env` and `.env.local` are gitignored — real secrets ONLY in `.env.local`.
# BC-F10: secrets live in `.env.local` so the runtime smoke's tempdir copy
# (which filters out `.env.local`) never sees them.

DATABASE_URL=postgresql://localhost:5432/commerce
PORT=9000

# Auth / session
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production

# CRM — Manta-issued contact identification token (HMAC-SHA256).
# Generate with: openssl rand -hex 32
MANTA_UID_SECRET=changeme

# AI agents (optional)
MANTA_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Analytics (optional — PostHog proxy + Klaviyo bridge)
POSTHOG_TOKEN=
POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_API_KEY=
KLAVIYO_API_KEY=

# GA4 Measurement Protocol dispatch (Event Hub -> GA4)
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
GA4_DEBUG=false

# Meta Conversions API dispatch (Event Hub -> Meta CAPI)
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=
META_CAPI_API_VERSION=v25.0

# Google Ads API dispatch (Event Hub purchase -> UploadClickConversions)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_PURCHASE_CONVERSION_ACTION_ID=
GOOGLE_ADS_API_VERSION=v24
GOOGLE_ADS_VALIDATE_ONLY=true

# Abandoned-cart relance (detect-abandoned-carts cron + notifyAbandonedCarts command)
# FRONT_BASE_URL  — used to build the customer recovery link sent to Klaviyo
# ADMIN_BASE_URL  — used to build the admin deep-link embedded in the ops event
FRONT_BASE_URL=https://fancypalas.com
ADMIN_BASE_URL=http://localhost:3000

# Shopify Admin API (used by src/modules/shopify-admin/*)
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_STORE=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_ADMIN_API_VERSION=2024-10

# Visitor identify endpoint (/api/_/c) — optional cache + CORS
# Leave UPSTASH_* empty in local dev: the endpoint no-ops its cache.
# In production, set them to use Upstash Redis for sub-request caching.
# Two naming conventions are accepted (adapter-native takes precedence):
#   1. Adapter-native:       UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
#   2. Vercel KV integration: UPSTASH_REDIS_KV_REST_API_URL / UPSTASH_REDIS_KV_REST_API_TOKEN
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Comma-separated origins allowed to call /api/_/c.
# Each entry is either an exact origin or a subdomain wildcard.
# Wildcards use `*.` and match both the apex host and any direct subdomain:
#   https://*.fancypalas.com  matches  https://fancypalas.com, https://uk.fancypalas.com, https://www.fancypalas.com
#   but NOT                             https://evilfancypalas.com
ALLOWED_CORS_ORIGIN=https://*.fancypalas.com
