    "@mantajs/sdk": "0.2.0-beta.12",
    "@mantajs/ui": "0.2.0-beta.12",
    "@react-email/components": "^0.5.7",
    "@react-email/render": "^2.0.8",
    "drizzle-orm": "^0.35.3",
    "jiti": "^2.6.0",
    "lucide-react": "^0.460.0",
    "nitro": "3.0.260311-beta",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.2",
    "react-router-dom": "^7.13.2",
    "recharts": "^2.15.4",
    "zod": "^3.23.0"
