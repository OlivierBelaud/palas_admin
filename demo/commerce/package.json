{
  "name": "commerce",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "manta dev",
    "build": "manta generate && node scripts/prepare-root-spa-public.mjs && manta build --preset vercel --no-migrate && node scripts/patch-root-spa-vercel.mjs",
    "build:vercel": "manta generate && node scripts/prepare-root-spa-public.mjs && manta build --preset vercel --no-migrate && node scripts/patch-root-spa-vercel.mjs",
    "build:node": "manta generate && manta build --preset node",
    "start": "manta start",
    "generate": "manta generate",
    "db:generate": "manta db generate",
    "db:migrate": "manta db migrate",
    "rebuild:production": "tsx scripts/rebuild-production.ts"
  },
  "dependencies": {
    "@fastify/busboy": "^3.2.0",
    "@mantajs/adapter-cache-upstash": "0.2.0-beta.12",
    "@mantajs/adapter-database-pg": "0.2.0-beta.12",
    "@mantajs/adapter-file-vercel-blob": "0.2.0-beta.12",
    "@mantajs/adapter-h3": "0.2.0-beta.12",
    "@mantajs/adapter-jobs-vercel-cron": "0.2.0-beta.12",
    "@mantajs/adapter-logger-pino": "0.2.0-beta.12",
    "@mantajs/adapter-notification-resend": "0.2.0-beta.12",
    "@mantajs/adapter-queue-qstash": "0.2.0-beta.12",
    "@mantajs/cli": "0.2.0-beta.12",
    "@mantajs/core": "0.2.0-beta.12",
    "@mantajs/dashboard": "0.2.0-beta.12",
    "@mantajs/host-nitro": "0.2.0-beta.12",
