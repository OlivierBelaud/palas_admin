// title: No raw Error in demo apps
// description: Use MantaError instead of raw Error in app code. Scoped to demo/**.
// category: lint/manta/noRawError

language js

`throw new Error($_)` as $e where {
  $filename <: includes "demo/",
  not $filename <: includes ".test.",
  not $filename <: includes "/tests/",
  register_diagnostic(
    span=$e,
    message="Use MantaError instead of raw Error. Example: throw new MantaError('UNEXPECTED_STATE', 'message')",
    severity="error"
  )
}
