{
  "name": "manta-framework",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "demo/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:conformance": "vitest run packages/core/tests/conformance/",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run --workspaces build"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
