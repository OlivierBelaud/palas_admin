{
  "name": "manta-framework",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "demo/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:conformance": "vitest run packages/core/tests/conformance/",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p packages/dashboard-core && tsc --noEmit -p packages/dashboard && tsc --noEmit -p packages/dashboard-medusa && tsc --noEmit -p packages/sdk && tsc --noEmit -p packages/ui",
    "lint": "biome check packages/ demo/",
    "lint:fix": "biome check --write packages/ demo/",
    "format": "biome format --write packages/ demo/",
    "check": "biome check --write packages/ demo/ && tsc --noEmit && vitest run",
    "check:fast": "biome check packages/ demo/ && tsc --noEmit",
    "prepare": "simple-git-hooks",
    "build": "npm run --workspaces build"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check:fast"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.18.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^2.0.0"
  }
}
